FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

// ドメイン: 200m x 200m x 80m (爆心を中央に)
// 格子: 100 x 100 x 40 = 400,000 セル

convertToMeters 1;

vertices
(
    (-100 -100  0)   // 0
    ( 100 -100  0)   // 1
    ( 100  100  0)   // 2
    (-100  100  0)   // 3
    (-100 -100 80)   // 4
    ( 100 -100 80)   // 5
    ( 100  100 80)   // 6
    (-100  100 80)   // 7
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (100 100 40) simpleGrading (1 1 1)
);

edges ();

boundary
(
    ground
    {
        type wall;
        faces
        (
            (0 1 2 3)
        );
    }
    top
    {
        type patch;
        faces
        (
            (4 5 6 7)
        );
    }
    sides
    {
        type patch;
        faces
        (
            (0 1 5 4)
            (1 2 6 5)
            (2 3 7 6)
            (3 0 4 7)
        );
    }
);

mergePatchPairs ();
